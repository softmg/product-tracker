# ------------------------------------------------------------
# Product Tracker production environment (docker compose)
# ------------------------------------------------------------

# Domains
APP_DOMAIN=tracker.example.com
API_DOMAIN=api.tracker.example.com
FRONTEND_PUBLIC_URL=https://tracker.example.com
BACKEND_PUBLIC_URL=https://api.tracker.example.com

# Traefik / Let's Encrypt
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
LETSENCRYPT_EMAIL=infra@example.com

# Backend runtime
APP_ENV=production
APP_DEBUG=false
# Generate with:
# docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.prod run --rm backend php artisan key:generate --show
APP_KEY=

# Database credentials
POSTGRES_DB=product_tracker
POSTGRES_USER=tracker
POSTGRES_PASSWORD=change_me_strong_password

# Frontend API target (public, consumed by browser)
NEXT_PUBLIC_API_URL=https://api.tracker.example.com
NEXT_PUBLIC_USE_MOCKS=false

# Session / Sanctum
SESSION_DOMAIN=.tracker.example.com
# Comma-separated list, without protocol
SANCTUM_STATEFUL_DOMAINS=tracker.example.com,api.tracker.example.com

# Optional admin reset helper
ADMIN_EMAIL=
ADMIN_PASSWORD=
