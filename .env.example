# ------------------------------------------------------------
# Product Tracker local environment (docker-compose)
# ------------------------------------------------------------

# App runtime mode used by backend service
APP_ENV=local
APP_DEBUG=true

# ------------------------------------------------------------
# Host ports (change if occupied on your machine)
# ------------------------------------------------------------
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379

# ------------------------------------------------------------
# PostgreSQL bootstrap credentials
# ------------------------------------------------------------
POSTGRES_DB=product_tracker
POSTGRES_USER=tracker
POSTGRES_PASSWORD=secret

# ------------------------------------------------------------
# Frontend runtime config
# ------------------------------------------------------------
# Used in Next.js as public API origin (without /api suffix)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Set to "true" to use local mock data instead of the real API.
# Useful for frontend-only development without a running backend.
# In production leave this unset or set to "false".
NEXT_PUBLIC_USE_MOCKS=false

# ------------------------------------------------------------
# Test credential overrides (optional)
# ------------------------------------------------------------
# Leave empty to use generated non-hardcoded values.
# You can still override each value individually with TEST_* variables.
E2E_DEFAULT_PASSWORD=
E2E_INVALID_PASSWORD=
TEST_ADMIN_EMAIL=
TEST_ADMIN_PASSWORD=
TEST_INITIATOR_EMAIL=
TEST_INITIATOR_PASSWORD=
TEST_PD_MANAGER_EMAIL=
TEST_PD_MANAGER_PASSWORD=
TEST_INVALID_EMAIL=
TEST_INVALID_PASSWORD=
TEST_NEW_USER_PASSWORD=
